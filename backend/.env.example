SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_NAME=ngo_db
DB_USER=ngo_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
